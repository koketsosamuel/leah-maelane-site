---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Leah Maelane — South African fashion model celebrating heritage through high fashion. Available for editorial, commercial, and runway bookings worldwide.',
  ogImage = '/images/hero.jpg'
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://leahmaelane.com');
const ogImageURL = new URL(ogImage, Astro.site || 'https://leahmaelane.com');
const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL.href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL.href} />
    <meta property="og:locale" content="en_ZA" />
    <meta property="og:site_name" content="Leah Maelane" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL.href} />

    <!-- Preconnect for Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

    <!-- Preload hero image for LCP -->
    <link rel="preload" as="image" href="/images/hero.jpg" fetchpriority="high" />

    <!-- Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Leah Maelane",
      "jobTitle": "Fashion Model",
      "url": "https://leahmaelane.com",
      "image": "https://leahmaelane.com/images/portrait-beauty.jpg",
      "description": "South African fashion model celebrating heritage through high fashion",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Pretoria",
        "addressCountry": "ZA"
      },
      "email": "leahmaelane14@gmail.com",
      "telephone": "+27848066821",
      "sameAs": [
        "https://www.instagram.com/leahmaelane",
        "https://www.facebook.com/share/1AEHJSNtki/?mibextid=wwXIfr"
      ]
    })} />

    {isProd && (
      <script defer src="https://umami.client.brightsync.co.za/script.js" data-website-id="aca3e39d-aaa3-45b9-bc18-80f093d833e9" data-auto-track="true" data-do-not-track="true" data-domains="leahmaelane.com" is:inline></script>
    )}
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
