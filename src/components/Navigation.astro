---
interface Props {
  variant?: 'light' | 'dark' | 'overlay';
  activeLink?: string;
}

const { variant = 'dark', activeLink = '' } = Astro.props;
const isOverlay = variant === 'overlay';
const isLight = variant === 'light';

const links = [
  { href: '/', label: 'HOME' },
  { href: '/portfolio', label: 'PORTFOLIO' },
  { href: '/about', label: 'ABOUT' },
  { href: '/contact', label: 'CONTACT' },
];
---

<nav class:list={['nav', { overlay: isOverlay, light: isLight }]}>
  <a href="/" class="logo">LEAH MAELANE</a>
  <button class="mobile-toggle" aria-label="Toggle menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
  <div class="nav-links">
    {links.map(link => (
      <a
        href={link.href}
        class:list={['nav-link', { active: activeLink === link.label }]}
      >
        {link.label}
      </a>
    ))}
    <a href="/contact" class="nav-cta">BOOKINGS</a>
  </div>
</nav>

<style>
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 56px;
    width: 100%;
    border-bottom: 1px solid var(--color-bg-alt);
    position: relative;
    z-index: 100;
  }

  .nav.overlay {
    position: absolute;
    top: 0;
    left: 0;
    border-bottom: none;
    padding: 32px 56px;
  }

  .nav.overlay .logo {
    color: var(--color-light);
  }

  .nav.overlay .nav-link {
    color: rgba(250, 248, 245, 0.67);
  }

  .nav.overlay .nav-link:hover,
  .nav.overlay .nav-link.active {
    color: var(--color-light);
  }

  .nav.overlay .nav-cta {
    color: var(--color-accent);
  }

  .logo {
    font-family: var(--font-heading);
    font-size: 22px;
    font-weight: normal;
    letter-spacing: 1px;
    color: var(--color-text-dark);
  }


  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 3px;
    color: var(--color-text-muted);
    transition: color 0.3s;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-accent);
  }

  .nav-cta {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--color-accent);
  }

  .mobile-toggle {
    display: none;
    flex-direction: column;
    gap: 6px;
    background: none;
    padding: 8px;
  }

  .mobile-toggle span {
    display: block;
    width: 28px;
    height: 2px;
    background: var(--color-text-dark);
    transition: all 0.3s;
  }

  .nav.overlay .mobile-toggle span {
    background: var(--color-light);
  }

  @media (max-width: 768px) {
    .nav {
      padding: 16px 24px;
    }

    .nav.overlay {
      padding: 16px 24px;
    }

    .mobile-toggle {
      display: flex;
    }

    .nav-links {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      background: var(--color-bg);
      padding: 24px;
      gap: 20px;
      box-shadow: 0 4px 20px rgba(0,0,0,0.1);
    }

    .nav-links.open {
      display: flex;
    }

    .nav.overlay .nav-links {
      background: rgba(46, 24, 84, 0.95);
    }
  }
</style>

<script>
  const toggle = document.querySelector('.mobile-toggle');
  const navLinks = document.querySelector('.nav-links');
  toggle?.addEventListener('click', () => {
    navLinks?.classList.toggle('open');
    const isOpen = navLinks?.classList.contains('open');
    toggle?.setAttribute('aria-expanded', String(isOpen));
  });
</script>
