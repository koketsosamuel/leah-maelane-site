---
interface Props {
  variant?: 'full' | 'simple';
}

const { variant = 'full' } = Astro.props;
---

<footer class="footer">
  {variant === 'full' && (
    <div class="geometric-border">
      <span class="seg gold"></span>
      <span class="seg copper"></span>
      <span class="seg gold"></span>
      <span class="seg copper"></span>
      <span class="seg gold"></span>
      <span class="seg copper"></span>
      <span class="seg gold"></span>
      <span class="seg copper"></span>
    </div>
  )}
  {variant === 'simple' && (
    <div class="footer-border-gradient"></div>
  )}
  <div class="footer-content">
    <div class="footer-top">
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <img src="/logo.png" alt="Leah Maelane" width="1359" height="620" />
        </a>
        {variant === 'full' ? (
          <p class="footer-tagline">South African Model &middot; Storyteller &middot; Muse</p>
        ) : (
          <p class="footer-tagline">Celebrating African beauty and heritage</p>
        )}
      </div>
      <div class="footer-links">
        <div class="footer-col">
          <span class="footer-col-title">Navigate</span>
          <a href="/">Home</a>
          <a href="/portfolio">Portfolio</a>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
        </div>
        <div class="footer-col">
          <span class="footer-col-title">Connect</span>
          <a href="https://www.instagram.com/leahmaelane" target="_blank" rel="noopener noreferrer">Instagram</a>
          <a href="https://www.facebook.com/share/1AEHJSNtki/?mibextid=wwXIfr" target="_blank" rel="noopener noreferrer">Facebook</a>
        </div>
      </div>
      <div class="footer-social">
        <a href="https://www.instagram.com/leahmaelane" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
        </a>
        <a href="https://www.facebook.com/share/1AEHJSNtki/?mibextid=wwXIfr" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>
    {variant === 'full' && (
      <div class="footer-bottom-section">
        <div class="footer-divider-gold"></div>
        <p class="copyright">&copy; 2026 Leah Maelane. All rights reserved.</p>
      </div>
    )}
    {variant === 'simple' && (
      <div class="footer-bottom-section">
        <p class="footer-quote">&ldquo;Umuntu ngumuntu ngabantu&rdquo;</p>
        <div class="footer-divider"></div>
        <div class="footer-bottom-row">
          <p class="copyright">&copy; 2026 Leah Maelane. All rights reserved.</p>
          <div class="footer-bottom-social">
            <a href="https://www.instagram.com/leahmaelane" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
            </a>
            <a href="https://www.facebook.com/share/1AEHJSNtki/?mibextid=wwXIfr" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
          </div>
        </div>
      </div>
    )}
  </div>
</footer>

<style>
  .footer {
    background: var(--color-footer);
    color: var(--color-light);
    width: 100%;
  }

  .geometric-border {
    display: flex;
    height: 4px;
  }

  .geometric-border .seg {
    flex: 1;
    height: 4px;
  }

  .geometric-border .gold {
    background: var(--color-accent);
  }

  .geometric-border .copper {
    background: var(--color-accent-alt);
  }

  .footer-border-gradient {
    height: 3px;
    background: linear-gradient(90deg, var(--color-accent), var(--color-accent-alt) 50%, var(--color-accent));
  }

  .footer-content {
    padding: 48px 80px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
  }

  .footer-logo img {
    height: 44px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .footer-tagline {
    font-size: 13px;
    color: rgba(250, 246, 240, 0.67);
    line-height: 1.5;
    max-width: 280px;
  }

  .footer-links {
    display: flex;
    gap: 48px;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-col-title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .footer-col a {
    font-size: 13px;
    color: rgba(250, 246, 240, 0.8);
    transition: color 0.3s;
  }

  .footer-col a:hover {
    color: var(--color-light);
  }

  .footer-social {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .footer-social a {
    color: rgba(250, 246, 240, 0.8);
    transition: color 0.3s;
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

  .footer-bottom-section {
    display: flex;
    flex-direction: column;
    gap: 32px;
    align-items: center;
  }

  .footer-divider-gold {
    width: 60px;
    height: 1px;
    background: var(--color-accent);
    opacity: 0.5;
  }

  .footer-divider {
    width: 100%;
    height: 1px;
    background: rgba(250, 246, 240, 0.08);
  }

  .footer-quote {
    font-family: var(--font-heading);
    font-size: 14px;
    font-style: italic;
    color: rgba(250, 248, 245, 0.25);
  }

  .footer-bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .footer-bottom-social {
    display: flex;
    gap: 16px;
  }

  .footer-bottom-social a {
    color: rgba(250, 248, 245, 0.5);
    transition: color 0.3s;
  }

  .footer-bottom-social a:hover {
    color: var(--color-accent);
  }

  .copyright {
    font-size: 12px;
    color: rgba(250, 248, 245, 0.38);
    letter-spacing: 1px;
  }

  @media (max-width: 768px) {
    .footer-content {
      padding: 32px 24px;
    }

    .footer-top {
      flex-direction: column;
      gap: 32px;
    }

    .footer-bottom-row {
      flex-direction: column;
      gap: 16px;
    }
  }
</style>
