---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const photos = [
  // Row 1 - 2 col
  { src: '/images/runway-safw-traditional.jpg', title: 'SA Fashion Week — Traditional Collection', credits: 'SA Fashion Week Runway', alt: 'Traditional outfit at SA Fashion Week' },
  { src: '/images/traditional-heritage-red.jpg', title: 'Heritage — Striped Collection', credits: 'Heritage Editorial Shoot', alt: 'Traditional striped outfit with red backdrop' },
  // Row 2 - asymmetric
  { src: '/images/editorial-pink-sequin.jpg', title: 'Mirror Mirror — Pink Sequin', credits: 'Editorial Shoot', alt: 'Pink sequin gown with mirror backdrop', height: 480 },
  { src: '/images/commercial-glade.jpg', title: 'Glade Campaign', credits: 'Commercial Campaign', alt: 'Glade commercial event', height: 360 },
  { src: '/images/hero.jpg', title: 'Golden Hour — Body Paint Editorial', credits: 'Editorial Shoot', alt: 'Gold body paint editorial', height: 884 },
  { src: '/images/beauty-bw-satin.jpg', title: 'Monochrome — Satin Series', credits: 'Beauty Editorial', alt: 'Black and white satin dress portrait', height: 884 },
  // Row 3
  { src: '/images/runway-green-halter.jpg', title: 'Emerald — Halter Collection', credits: 'Soweto Fashion Week', alt: 'Green halter dress on runway' },
  { src: '/images/editorial-green-suit.jpg', title: 'Power Suit — Retro Editorial', credits: 'Retro Editorial Shoot', alt: 'Green power suit with vintage TV' },
  { src: '/images/beauty-pink-closeup.jpg', title: 'Skin Deep — Beauty Edit', credits: 'Beauty Editorial', alt: 'Pink sequin dress close-up portrait' },
];
---

<BaseLayout title="Portfolio — Leah Maelane">
  <Navigation activeLink="PORTFOLIO" />

  <!-- Page Header -->
  <section class="page-header">
    <h1 class="page-title">Portfolio</h1>
    <p class="page-subtitle">A curated collection of editorial, commercial & runway work</p>
    <div class="header-divider"></div>
  </section>

  <!-- Photo Grid -->
  <section class="photo-grid">
    <!-- Row 1 -->
    <div class="grid-row grid-row-2">
      {photos.slice(0, 2).map(photo => (
        <div class="photo-wrap">
          <div class="photo-frame">
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          </div>
          <div class="photo-caption">
            <p class="caption-title">{photo.title}</p>
            <p class="caption-credits">{photo.credits}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Row 2 - Asymmetric -->
    <div class="grid-row grid-row-asymmetric">
      <div class="asym-left">
        <div class="photo-wrap">
          <div class="photo-frame" style="height: 480px;">
            <img src={photos[2].src} alt={photos[2].alt} loading="lazy" />
          </div>
          <div class="photo-caption">
            <p class="caption-title">{photos[2].title}</p>
            <p class="caption-credits">{photos[2].credits}</p>
          </div>
        </div>
        <div class="photo-wrap">
          <div class="photo-frame" style="height: 360px;">
            <img src={photos[3].src} alt={photos[3].alt} loading="lazy" />
          </div>
          <div class="photo-caption">
            <p class="caption-title">{photos[3].title}</p>
            <p class="caption-credits">{photos[3].credits}</p>
          </div>
        </div>
      </div>
      <div class="photo-wrap asym-right">
        <div class="photo-frame" style="height: 884px;">
          <img src={photos[4].src} alt={photos[4].alt} loading="lazy" />
        </div>
        <div class="photo-caption">
          <p class="caption-title">{photos[4].title}</p>
          <p class="caption-credits">{photos[4].credits}</p>
        </div>
      </div>
      <div class="photo-wrap asym-right">
        <div class="photo-frame" style="height: 884px;">
          <img src={photos[5].src} alt={photos[5].alt} loading="lazy" />
        </div>
        <div class="photo-caption">
          <p class="caption-title">{photos[5].title}</p>
          <p class="caption-credits">{photos[5].credits}</p>
        </div>
      </div>
    </div>

    <!-- Row 3 -->
    <div class="grid-row grid-row-3">
      {photos.slice(6, 9).map(photo => (
        <div class="photo-wrap">
          <div class="photo-frame" style="height: 520px;">
            <img src={photo.src} alt={photo.alt} loading="lazy" />
          </div>
          <div class="photo-caption">
            <p class="caption-title">{photo.title}</p>
            <p class="caption-credits">{photo.credits}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <Footer variant="full" />
</BaseLayout>

<style>
  .page-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    padding: 80px 56px 48px;
  }

  .page-title {
    font-family: var(--font-heading);
    font-size: clamp(36px, 5vw, 72px);
    font-weight: normal;
    color: var(--color-text-dark);
  }

  .page-subtitle {
    font-size: 18px;
    font-weight: 300;
    color: var(--color-text-muted);
    text-align: center;
  }

  .header-divider {
    width: 60px;
    height: 2px;
    background: var(--color-accent);
  }

  .photo-grid {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 0 56px 48px;
  }

  .grid-row {
    display: flex;
    gap: 24px;
  }

  .grid-row-2 .photo-wrap,
  .grid-row-3 .photo-wrap {
    flex: 1;
  }

  .grid-row-2 .photo-frame {
    height: 620px;
  }

  .grid-row-asymmetric {
    display: flex;
    gap: 24px;
  }

  .asym-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .asym-right {
    flex: 1;
  }

  .photo-wrap {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .photo-frame {
    overflow: hidden;
    width: 100%;
  }

  .photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .photo-frame:hover img {
    transform: scale(1.03);
  }

  .photo-caption {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .caption-title {
    font-family: var(--font-heading);
    font-size: 14px;
    color: var(--color-text-dark);
  }

  .caption-credits {
    font-size: 11px;
    font-weight: 300;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 48px 24px 32px;
    }

    .photo-grid {
      padding: 0 24px 32px;
    }

    .grid-row,
    .grid-row-asymmetric {
      flex-direction: column;
    }

    .grid-row-2 .photo-frame,
    .photo-frame {
      height: 300px !important;
    }
  }
</style>
