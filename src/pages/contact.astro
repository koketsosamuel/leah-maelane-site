---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Book Leah Maelane | Modelling Enquiries & Collaborations" description="Book Leah Maelane for your next editorial, commercial, or runway project. Get in touch for worldwide modelling bookings and collaborations." ogImage="/images/portrait-bw-elegant.jpg">
  <Navigation activeLink="CONTACT" />
  <div class="nav-divider"></div>

  <section class="contact-main">
    <div class="contact-left">
      <h1 class="contact-heading">Let's Create<br>Something Beautiful</h1>
      <p class="contact-subtitle">
        Whether it's a campaign, editorial, runway show, or cultural celebration — I'd love to hear from you.
      </p>

      <div class="dot-accent">
        <span class="dot gold"></span>
        <span class="dot copper"></span>
        <span class="dot gold"></span>
        <span class="dot red"></span>
        <span class="dot gold"></span>
      </div>

      <div class="gold-line"></div>

      <!-- Contact Info -->
      <div class="contact-info">
        <div class="info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <a href="mailto:leahmaelane14@gmail.com">leahmaelane14@gmail.com</a>
        </div>
        <div class="info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <a href="tel:+27848066821">084 806 6821</a>
        </div>
        <div class="info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Pretoria, South Africa</span>
        </div>
      </div>

      <!-- Social Links -->
      <div class="social-links">
        <span class="social-label">FOLLOW THE JOURNEY</span>
        <div class="social-divider"></div>
        <a href="https://www.instagram.com/leahmaelane" aria-label="Instagram" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
        </a>
        <a href="https://www.facebook.com/share/1AEHJSNtki/?mibextid=wwXIfr" aria-label="Facebook" rel="noopener noreferrer" target="_blank">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
      </div>
    </div>

    <div class="contact-image">
      <img src="/images/contact-beauty-portrait.jpg" alt="Leah Maelane beauty portrait with makeup brushes" width="1000" height="1250" loading="lazy" />
    </div>
  </section>

  <Footer variant="simple" />
</BaseLayout>

<style>
  .nav-divider {
    width: 100%;
    height: 1px;
    background: var(--color-bg-alt);
  }

  .contact-main {
    display: flex;
    gap: 80px;
    padding: 80px;
  }

  .contact-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .contact-heading {
    font-family: var(--font-heading);
    font-size: clamp(24px, 3.3vw, 48px);
    font-weight: normal;
    line-height: 1.15;
    color: var(--color-text-dark);
  }

  .contact-subtitle {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .dot-accent {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .dot.gold { background: var(--color-accent); }
  .dot.copper { background: var(--color-accent-alt); }
  .dot.red { background: #C4302B; }

  .gold-line {
    width: 60px;
    height: 2px;
    background: var(--color-accent);
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--color-bg-alt);
    padding: 20px 24px;
    border-radius: 4px;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--color-text-dark);
  }

  .info-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .info-row a {
    color: var(--color-text-dark);
    transition: color 0.3s;
  }

  .info-row a:hover {
    color: var(--color-accent);
  }

  /* Social */
  .social-links {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .social-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--color-text-muted);
  }

  .social-divider {
    width: 40px;
    height: 1px;
    background: var(--color-accent);
  }

  .social-links a {
    color: var(--color-text-muted);
    transition: color 0.3s;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  /* Right Image */
  .contact-image {
    width: 500px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .contact-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
  }

  @media (max-width: 1024px) {
    .contact-main {
      padding: 40px;
      gap: 40px;
    }

    .contact-image {
      width: 380px;
    }
  }

  @media (max-width: 768px) {
    .contact-main {
      flex-direction: column-reverse;
      padding: 24px;
    }

    .contact-image {
      width: 100%;
      height: 400px;
    }
  }
</style>
