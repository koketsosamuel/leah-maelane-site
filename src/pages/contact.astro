---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout title="Contact — Leah Maelane">
  <Navigation activeLink="CONTACT" />
  <div class="nav-divider"></div>

  <section class="contact-main">
    <div class="contact-left">
      <h1 class="contact-heading">Let's Create<br>Something Beautiful</h1>
      <p class="contact-subtitle">
        Whether it's a campaign, editorial, runway show, or cultural celebration — I'd love to hear from you.
      </p>

      <div class="dot-accent">
        <span class="dot gold"></span>
        <span class="dot copper"></span>
        <span class="dot gold"></span>
        <span class="dot red"></span>
        <span class="dot gold"></span>
      </div>

      <div class="gold-line"></div>

      <!-- Contact Info Card -->
      <div class="contact-info">
        <div class="info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          <span>leah@leahmaelane.com</span>
        </div>
        <div class="info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          <span>+27 81 234 5678</span>
        </div>
        <div class="info-row">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="info-icon"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Johannesburg, South Africa</span>
        </div>
      </div>

      <!-- Contact Form -->
      <form class="contact-form" action="#" method="POST">
        <div class="form-field">
          <label class="form-label">YOUR NAME</label>
          <div class="form-input-wrap">
            <input type="text" placeholder="Enter your full name" class="form-input" />
          </div>
        </div>
        <div class="form-field">
          <label class="form-label">EMAIL ADDRESS</label>
          <div class="form-input-wrap">
            <input type="email" placeholder="you@email.com" class="form-input" />
          </div>
        </div>
        <div class="form-field">
          <label class="form-label">SUBJECT</label>
          <div class="form-input-wrap select-wrap">
            <select class="form-input form-select">
              <option value="">Select enquiry type</option>
              <option value="editorial">Editorial</option>
              <option value="commercial">Commercial</option>
              <option value="runway">Runway</option>
              <option value="collaboration">Collaboration</option>
              <option value="other">Other</option>
            </select>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="select-arrow"><polyline points="6 9 12 15 18 9"/></svg>
          </div>
        </div>
        <div class="form-field">
          <label class="form-label">YOUR MESSAGE</label>
          <div class="form-input-wrap textarea-wrap">
            <textarea placeholder="Tell us about your project or vision..." class="form-input form-textarea" rows="5"></textarea>
          </div>
        </div>
        <button type="submit" class="submit-btn">
          <span>SEND ENQUIRY</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </button>
      </form>

      <!-- Social Links -->
      <div class="social-links">
        <span class="social-label">FOLLOW THE JOURNEY</span>
        <div class="social-divider"></div>
        <a href="#" aria-label="Instagram">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5"/></svg>
        </a>
        <a href="#" aria-label="Facebook">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
        </a>
        <a href="#" aria-label="Twitter">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
        </a>
      </div>
    </div>

    <div class="contact-image">
      <img src="https://images.unsplash.com/photo-1614709445081-23465e205471?w=1000&q=80" alt="Leah Maelane" />
    </div>
  </section>

  <Footer variant="simple" />
</BaseLayout>

<style>
  .nav-divider {
    width: 100%;
    height: 1px;
    background: var(--color-bg-alt);
  }

  .contact-main {
    display: flex;
    gap: 80px;
    padding: 80px;
  }

  .contact-left {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .contact-heading {
    font-family: var(--font-heading);
    font-size: clamp(32px, 3.3vw, 48px);
    font-weight: normal;
    line-height: 1.15;
    color: var(--color-text-dark);
  }

  .contact-subtitle {
    font-size: 17px;
    font-weight: 300;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .dot-accent {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .dot.gold { background: var(--color-accent); }
  .dot.copper { background: var(--color-accent-alt); }
  .dot.red { background: #C4302B; }

  .gold-line {
    width: 60px;
    height: 2px;
    background: var(--color-accent);
  }

  /* Contact Info */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--color-bg-alt);
    padding: 20px 24px;
    border-radius: 4px;
  }

  .info-row {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 15px;
    color: var(--color-text-dark);
  }

  .info-icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  /* Form */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--color-text-muted);
  }

  .form-input-wrap {
    border-bottom: 1px solid var(--color-bg-alt);
    padding-bottom: 12px;
  }

  .form-input {
    width: 100%;
    font-size: 15px;
    color: var(--color-text-dark);
    background: transparent;
    padding: 8px 0;
  }

  .form-input::placeholder {
    color: #B5A89E;
  }

  .select-wrap {
    position: relative;
    display: flex;
    align-items: center;
  }

  .form-select {
    appearance: none;
    cursor: pointer;
    padding-right: 24px;
  }

  .select-arrow {
    position: absolute;
    right: 0;
    color: var(--color-text-muted);
    pointer-events: none;
  }

  .textarea-wrap {
    border-bottom: 1px solid var(--color-bg-alt);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
    padding: 12px 0;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--color-accent);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    padding: 16px 40px;
    align-self: flex-start;
    transition: background 0.3s;
  }

  .submit-btn:hover {
    background: var(--color-accent-alt);
  }

  /* Social */
  .social-links {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .social-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 2px;
    color: var(--color-text-muted);
  }

  .social-divider {
    width: 40px;
    height: 1px;
    background: var(--color-accent);
  }

  .social-links a {
    color: var(--color-text-muted);
    transition: color 0.3s;
  }

  .social-links a:hover {
    color: var(--color-accent);
  }

  /* Right Image */
  .contact-image {
    width: 500px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .contact-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 1024px) {
    .contact-main {
      padding: 40px;
      gap: 40px;
    }

    .contact-image {
      width: 380px;
    }
  }

  @media (max-width: 768px) {
    .contact-main {
      flex-direction: column-reverse;
      padding: 24px;
    }

    .contact-image {
      width: 100%;
      height: 400px;
    }
  }
</style>
