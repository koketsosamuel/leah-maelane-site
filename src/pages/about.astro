---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';

const stats = [
  { label: 'LOCATION', value: 'Pretoria, SA' },
];

const highlights = [
  { src: '/images/highlight-safw-traditional.jpg', title: 'SA Fashion Week', date: 'Spring 2025', alt: 'Traditional outfit at SA Fashion Week' },
  { src: '/images/highlight-soweto-red-dress.jpg', title: 'Soweto Fashion Week', date: 'August 2024', alt: 'Red tiered dress at Soweto Fashion Week' },
  { src: '/images/highlight-blue-coat.jpg', title: 'Blue Coat Collection', date: 'Summer 2024', alt: 'Blue coat runway show' },
  { src: '/images/highlight-glade-commercial.jpg', title: 'Glade Campaign', date: 'Fall 2024', alt: 'Glade commercial event' },
  { src: '/images/highlight-tut-show.jpg', title: 'TUT Fashion Show', date: 'Winter 2023', alt: 'TUT fashion show runway' },
  { src: '/images/editorial-neon-pink.jpg', title: 'Neon Nights Editorial', date: 'Spring 2024', alt: 'Neon pink street style editorial' },
  { src: '/images/editorial-gold-jumpsuit.jpg', title: 'Backstage — Gold', date: 'Summer 2023', alt: 'Gold patterned jumpsuit backstage' },
  { src: '/images/runway-denim-kimono.jpg', title: 'Creme Fashion Week', date: 'Fall 2023', alt: 'Denim kimono runway look' },
];
---

<BaseLayout title="About Leah Maelane | South African Fashion Model Based in Pretoria" description="Meet Leah Maelane — a Pretoria-born South African fashion model. From SA Fashion Week to global runways, she celebrates African heritage through fashion.">
  <Navigation activeLink="ABOUT" />
  <div class="nav-divider"></div>

  <!-- Hero / Bio Section -->
  <section class="about-hero">
    <div class="hero-portrait">
      <img src="/images/portrait-yellow-scarf.jpg" alt="Leah Maelane editorial portrait with yellow headscarf against red backdrop" width="1200" height="1575" fetchpriority="high" />
    </div>
    <div class="hero-bio">
      <span class="bio-tag">ABOUT ME</span>
      <h1 class="bio-heading">A Celebration of Heritage</h1>
      <p class="bio-text">
        Born in Pretoria and raised in tradition, I am Leah Maelane — a South African fashion model
        and a celebration of heritage on every stage I grace. From the beadwork of my grandmother to the
        runways of SA Fashion Week and Soweto Fashion Week, I carry my roots with pride.
      </p>
      <div class="gold-line"></div>
      <p class="bio-text">
        My journey as a model began on the streets of Pretoria, where culture and creativity collide.
        Today, I walk for editorial campaigns, commercial brands, and runway shows across South Africa and beyond —
        always carrying the spirit of African artistry with me. Whether it's a bold editorial shoot or a traditional
        collection on the catwalk, every frame tells a story of where I come from and where African fashion is going.
      </p>
    </div>
  </section>

  <!-- Stats -->
  <section class="stats-section">
    {stats.map((stat, i) => (
      <>
        <div class="stat">
          <span class="stat-label">{stat.label}</span>
          <span class="stat-value">{stat.value}</span>
        </div>
        {i < stats.length - 1 && <div class="stat-divider"></div>}
      </>
    ))}
  </section>

  <!-- Career Highlights -->
  <section class="highlights-section">
    <div class="highlights-header">
      <h2 class="highlights-title">Career Highlights</h2>
      <span class="highlights-tag">SCROLL TO EXPLORE</span>
    </div>
    <div class="filmstrip-container">
      <div class="filmstrip">
        {highlights.map(item => (
          <div class="filmstrip-item">
            <div class="filmstrip-img">
              <img src={item.src} alt={item.alt} loading="lazy" width="600" height="800" />
            </div>
            <div class="filmstrip-label">
              <p class="filmstrip-title">{item.title}</p>
              <p class="filmstrip-date">{item.date}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="about-cta">
    <a href="/portfolio" class="cta-link">VIEW MY PORTFOLIO →</a>
    <span class="cta-divider">|</span>
    <a href="/contact" class="cta-link">BOOK ME →</a>
  </section>

  <Footer variant="simple" />
</BaseLayout>

<style>
  .nav-divider {
    width: 100%;
    height: 1px;
    background: var(--color-bg-alt);
  }

  .about-hero {
    display: flex;
    height: 720px;
    width: 100%;
  }

  .hero-portrait {
    width: 620px;
    flex-shrink: 0;
    overflow: hidden;
  }

  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-bio {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 32px;
    padding: 80px 80px;
    background: var(--color-bg);
  }

  .bio-tag {
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--color-accent);
  }

  .bio-heading {
    font-family: var(--font-heading);
    font-size: clamp(22px, 3vw, 42px);
    font-weight: normal;
    line-height: 1.15;
    color: var(--color-text-dark);
  }

  .bio-text {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-text-muted);
  }

  .gold-line {
    width: 60px;
    height: 2px;
    background: var(--color-accent);
  }

  /* Stats */
  .stats-section {
    display: flex;
    justify-content: space-around;
    align-items: center;
    padding: 48px 80px;
    background: var(--color-bg-alt);
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .stat-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--color-accent);
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: clamp(20px, 2vw, 28px);
    color: var(--color-text-dark);
  }

  .stat-divider {
    width: 1px;
    height: 48px;
    background: var(--color-accent);
    opacity: 0.3;
  }

  /* Highlights */
  .highlights-section {
    padding: 64px 80px;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .highlights-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .highlights-title {
    font-family: var(--font-heading);
    font-size: 28px;
    font-weight: normal;
    color: var(--color-text-dark);
  }

  .highlights-tag {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 2px;
    color: var(--color-accent);
  }

  .filmstrip-container {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: var(--color-accent) transparent;
  }

  .filmstrip-container::-webkit-scrollbar {
    height: 4px;
  }

  .filmstrip-container::-webkit-scrollbar-track {
    background: transparent;
  }

  .filmstrip-container::-webkit-scrollbar-thumb {
    background: var(--color-accent);
    border-radius: 2px;
  }

  .filmstrip {
    display: flex;
    gap: 16px;
    width: max-content;
  }

  .filmstrip-item {
    display: flex;
    flex-direction: column;
    gap: 12px;
    width: 220px;
    flex-shrink: 0;
  }

  .filmstrip-img {
    width: 220px;
    height: 280px;
    overflow: hidden;
  }

  .filmstrip-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .filmstrip-img:hover img {
    transform: scale(1.05);
  }

  .filmstrip-label {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .filmstrip-title {
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-dark);
  }

  .filmstrip-date {
    font-size: 11px;
    color: var(--color-text-muted);
  }

  .about-cta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 32px;
    padding: 48px 80px;
    background: var(--color-bg-alt);
  }

  .cta-link {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 3px;
    color: var(--color-accent);
    transition: color 0.3s;
  }

  .cta-link:hover {
    color: var(--color-accent-alt);
  }

  .cta-divider {
    color: var(--color-accent);
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    .about-hero {
      flex-direction: column;
      height: auto;
    }

    .hero-portrait {
      width: 100%;
      height: 400px;
    }

    .hero-bio {
      padding: 40px 24px;
    }

    .stats-section {
      flex-direction: column;
      gap: 24px;
      padding: 32px 24px;
    }

    .stat-divider {
      width: 48px;
      height: 1px;
    }

    .highlights-section {
      padding: 40px 24px;
    }

    .highlights-header {
      flex-direction: column;
      gap: 8px;
      align-items: flex-start;
    }
  }
</style>
